      sudo paru -S --needed git brave baobab btop chezmoi github-cli gnome-disk-utility gnome-system-monitor ghostty neovim tmux vlc ripgrep 7zip nautilus showtime tree-sitter-cli zoxide skim mise fcitx5 fcitx5-unikey kcm-fcitx5
      paru -S sesh-bin
    {{   end -}}
{{ end -}}
